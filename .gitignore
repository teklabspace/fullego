# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare
.wrangler/
.dev.vars

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright test artifacts (console logs, page snapshots, screenshots)
/.playwright-mcp/

# generated PDFs
*.pdf

# ad-hoc screenshots dropped at the repo root during manual testing
# (real app images live under public/ and src/, which are unaffected)
/*.png

# scratch design/planning docs (specs, plans, working notes)
docs/superpowers/
